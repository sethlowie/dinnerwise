# Copy to .env and fill in. All values are optional except your OpenAI key
# (omit it to run the scripted, no-LLM fallback agent — fully offline).

# --- OpenAI (agent uses the Responses API) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano          # any model your account can access

# --- Server ---
# ADDR=:8080                     # listen address (default)
# DINNERWISE_DB=dinnerwise.db    # SQLite path (default; created + seeded on first run)

# --- Observability (optional) ---
# Leave the endpoint empty to disable telemetry. To export to the local
# Grafana stack from `make obs`, set it to the port-forwarded collector:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=dinnerwise
