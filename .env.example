# --- AI / models (OpenAI-compatible endpoint) ---
# Defaults target the in-cluster Ollama (qwen3). To use OpenAI instead:
#   AI_BASE_URL=https://api.openai.com/v1
#   AI_API_KEY=sk-...
#   AI_MODEL=gpt-5
#   AI_NANO_MODEL=gpt-5-nano
AI_BASE_URL=http://ollama.ai:11434/v1
AI_API_KEY=ollama
# Frontier model for planning and adaptation reasoning
AI_MODEL=qwen3:4b-instruct
# Small/cheap model for narrow, schema-constrained ingredient enrichment
AI_NANO_MODEL=qwen3:4b-instruct

# --- Database (MongoDB) ---
MONGODB_URI=mongodb://mongodb:27017/?directConnection=true
MONGODB_DB_NAME=dinnerwise

# --- Server ---
PORT=:8080
APP_ENV=dev
CORS_ORIGIN=http://localhost:5173

# --- Observability (LGTM all-in-one) ---
OTLP_ENDPOINT=lgtm:4318
# Left empty on purpose: the OTel auto-exporter trips on a malformed value.
OTEL_EXPORTER_OTLP_ENDPOINT=
